<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wkclz.micro.wxapp.dao.WxappUserMapper">

    <select id="getWxappUserByOpenId" parameterType="java.lang.String"
            resultType="com.wkclz.micro.wxapp.bean.entity.WxappUser">
        SELECT
            *
        FROM
            wxapp_user
        WHERE
            `status` = 1
            AND open_id = #{openId}
    </select>

    <select id="getWxappUserByUserCode" parameterType="java.lang.String"
            resultType="com.wkclz.micro.wxapp.bean.entity.WxappUser">
        SELECT
            *
        FROM
            wxapp_user
        WHERE
            `status` = 1
            AND user_code = #{userCode}
    </select>

</mapper>

